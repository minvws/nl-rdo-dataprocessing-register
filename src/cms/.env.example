APP_ENV=local
APP_KEY=
APP_URL=http://localhost
APP_DEBUG=true
APP_SERVICE=web

LOG_LEVEL=debug

DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_SECURE_COOKIE=false
SESSION_COOKIE=verwerkingsregister_session

VIRUSSCANNER_SOCKET=tcp://clamav:3310

OUTBOX_SMTP_FROM=hello@example.com
QUEUE_CONNECTION=sync
IP_WHITELIST_DEFAULTS=*.*.*.*
ONE_TIME_PASSWORD_DRIVER=fake

STATIC_WEBSITE_BASE_URL=http://localhost/static-website

# Configure bucket names for the disks, the same Minio/AWS configuration is used for both buckets.
UPLOADS_BUCKET=uploads
EXPORTS_BUCKET=exports

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=eu-central-1
MINIO_BUCKET=verwerkingsregister

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=verwerkingsregister
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

AUDIT_SYSLOG_BASE64_ENCODE_ENABLED=false
